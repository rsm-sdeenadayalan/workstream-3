# ─────────────────────────────────────────────────────────────────────────────
# Gramercy WS3 — CLDV (Cognitive Labor Displacement Velocity) — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# CLDV data lives in the `cldv` database. setup_cldv.py auto-creates it if missing.
# Same Postgres server hosts WS1 (gramercy_workstream1), WS2 (cii), and WS3 (cldv).
POSTGRES_HOST=localhost
POSTGRES_PORT=5440
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=cldv
# Existing DB to connect to in order to CREATE DATABASE cldv (server-dependent).
POSTGRES_BOOTSTRAP_DB=postgres

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for the research-agent fallback collector (SI1 transcript discovery,
# any cell a primary free source misses) and SI1 NLP first-pass classification.
ANTHROPIC_API_KEY=
CLAUDE_RESEARCH_MODEL=claude-haiku-4-5-20251001

# ── Tavily (web search backend) ───────────────────────────────────────────────
# Required for the research-agent fallback. Free tier: 1000 searches/month.
TAVILY_API_KEY=

# ── SI3 (World Bank) — no key required ────────────────────────────────────────
# CLDV_WB_MRV controls how many most-recent years to pull (default 6).
CLDV_WB_MRV=6

# ── Parallelism ───────────────────────────────────────────────────────────────
# Worker threads for the I/O-bound SI1 transcript/agent cells.
CLDV_MAX_WORKERS=6
